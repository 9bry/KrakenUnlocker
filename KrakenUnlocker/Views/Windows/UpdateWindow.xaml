<Window x:Class="KrakenUnlocker.Views.Windows.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Required"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Window.Resources>
        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="#FF3333">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF1111"/>
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF0000" BlurRadius="18" ShadowDepth="0" Opacity="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#990000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#555555"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Drop shadow container -->
    <Border CornerRadius="12" Background="#0D0D0D"
            BorderThickness="1" BorderBrush="#CC0000">
        <Border.Effect>
            <DropShadowEffect Color="#CC0000" BlurRadius="40" ShadowDepth="0" Opacity="0.35"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header bar - draggable -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Background="#0D0D0D"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Padding="24,18,24,14">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Animated red dot -->
                        <Ellipse Width="10" Height="10" Fill="#CC0000" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.2" Duration="0:0:0.8"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="KRAKEN XBOX UNLOCKER" Foreground="#CC0000"
                                   FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="UPDATE REQUIRED" Foreground="#FF0033"
                               FontWeight="Bold" FontSize="11"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Divider line -->
            <Rectangle Grid.Row="0" Height="1" Fill="#1A0000"
                       VerticalAlignment="Bottom" Margin="0,0,0,-1"/>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="28,20,28,16" VerticalAlignment="Center">

                <!-- Icon + title -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                    <TextBlock Text="&#x26A0;" FontSize="28" Foreground="#FF3333"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="New Update Available" FontSize="22" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Version pill -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                    <Border Background="#1A0505" BorderBrush="#550000" BorderThickness="1"
                            CornerRadius="20" Padding="14,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Current: " Foreground="#666" FontSize="12"/>
                            <TextBlock x:Name="CurrentVersionText" Foreground="#888" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="→" Foreground="#CC0000" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="#1A0000" BorderBrush="#CC0000" BorderThickness="1"
                            CornerRadius="20" Padding="14,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Latest: " Foreground="#888" FontSize="12"/>
                            <TextBlock x:Name="NewVersionText" Foreground="#FF3333" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Description box -->
                <Border Background="#0F0F0F" BorderBrush="#1A1A1A" BorderThickness="1"
                        CornerRadius="8" Padding="14,10" Margin="0,0,0,16" MaxHeight="100">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ChangelogText"
                                   Foreground="#888888" FontSize="12"
                                   TextWrapping="Wrap" LineHeight="18"/>
                    </ScrollViewer>
                </Border>

                <Border Background="#1A0505" BorderBrush="#440000" BorderThickness="1"
                        CornerRadius="6" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F512;" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="The app is locked until you update."
                                   Foreground="#CC4444" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="2" Margin="28,0,28,22">
                <Button x:Name="DownloadButton"
                        Style="{StaticResource GlowButton}"
                        Content="⬇  Download Update"
                        Click="DownloadButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
