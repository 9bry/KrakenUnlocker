<UserControl x:Class="KrakenUnlocker.Views.Controls.KrakenLoader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200"
             d:DesignWidth="200"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <UserControl.Resources>
        <Storyboard x:Key="KrakenSpinClockwise" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="OrbitRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:2.5"/>
        </Storyboard>
        <Storyboard x:Key="KrakenSpinCounter" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="360" To="0" Duration="0:0:2.6"/>
        </Storyboard>
        <Storyboard x:Key="KrakenPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="CoreGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.35" To="0.95" Duration="0:0:0.85"/>
            <DoubleAnimation Storyboard.TargetName="CoreIcon"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.92" To="1.08" Duration="0:0:0.85"/>
            <DoubleAnimation Storyboard.TargetName="CoreIcon"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.92" To="1.08" Duration="0:0:0.85"/>
        </Storyboard>
        <Storyboard x:Key="KrakenSweep" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SweepArc"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.8"/>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource KrakenSpinClockwise}"/>
            <BeginStoryboard Storyboard="{StaticResource KrakenSpinCounter}"/>
            <BeginStoryboard Storyboard="{StaticResource KrakenPulse}"/>
            <BeginStoryboard Storyboard="{StaticResource KrakenSweep}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Width="200" Height="200">
        <Ellipse x:Name="CoreGlow"
                 Width="150" Height="150"
                 Opacity="0.55"
                 Fill="{DynamicResource KrakenRedMutedBrush}">
            <Ellipse.Effect>
                <BlurEffect Radius="28"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="148" Height="148"
                 Stroke="#330000"
                 StrokeThickness="1"
                 Opacity="0.8"/>

        <Ellipse x:Name="OrbitRing"
                 Width="132" Height="132"
                 Stroke="{DynamicResource KrakenRedGlowBrush}"
                 StrokeThickness="2.5"
                 StrokeDashArray="18 6 4 6"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform Angle="0"/>
            </Ellipse.RenderTransform>
            <Ellipse.Effect>
                <DropShadowEffect Color="#FF0033" BlurRadius="16" ShadowDepth="0" Opacity="0.55"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse x:Name="PulseRing"
                 Width="108" Height="108"
                 Stroke="{DynamicResource KrakenRedBrush}"
                 StrokeThickness="1.5"
                 StrokeDashArray="4 8"
                 Opacity="0.75"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform Angle="0"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <Path x:Name="SweepArc"
              Width="96" Height="96"
              RenderTransformOrigin="0.5,0.5"
              Stroke="{DynamicResource KrakenRedNeonBrush}"
              StrokeThickness="4"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Data="M 48,8 A 40,40 0 0 1 88,48">
            <Path.RenderTransform>
                <RotateTransform Angle="0"/>
            </Path.RenderTransform>
            <Path.Effect>
                <DropShadowEffect Color="#FF1744" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
            </Path.Effect>
        </Path>

        <Border x:Name="CoreIcon"
                Width="52" Height="52"
                CornerRadius="26"
                BorderBrush="{DynamicResource KrakenAccentGradient}"
                BorderThickness="2"
                Background="#080808"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#E10600" BlurRadius="20" ShadowDepth="0" Opacity="0.65"/>
            </Border.Effect>
            <Image Source="pack://application:,,,/Retro360.ico"
                   Stretch="Uniform"
                   Margin="6"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,4">
            <TextBlock Text="KRAKEN"
                       FontSize="11"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource KrakenRedGlowBrush}"/>
            <TextBlock Text="{Binding StatusText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="10"
                       Margin="0,2,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
