<UserControl x:Class="KrakenUnlocker.Views.Controls.AnimatedBackground"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid x:Name="RootGrid" ClipToBounds="True">
        <!-- Base gradient background -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0A0A" Offset="0"/>
                    <GradientStop Color="#1A1A1A" Offset="0.5"/>
                    <GradientStop Color="#0A0A0A" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        
        <!-- Animated hex grid canvas -->
        <Canvas x:Name="HexCanvas" Background="Transparent">
            <Canvas.Resources>
                <!-- Animated hex node style -->
                <Style x:Key="HexNode" TargetType="Ellipse">
                    <Style.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                   From="0.2" To="0.6" Duration="0:0:3"
                                                   AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Style.Triggers>
                </Style>
            </Canvas.Resources>
        </Canvas>
        
        <!-- Vignette overlay -->
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="Transparent" Offset="0.3"/>
                    <GradientStop Color="#AA000000" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>
