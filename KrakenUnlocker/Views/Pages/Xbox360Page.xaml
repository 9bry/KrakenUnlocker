<Page x:Class="KrakenUnlocker.Views.Pages.Xbox360Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:KrakenUnlocker.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      d:DesignHeight="720" d:DesignWidth="1100"
      mc:Ignorable="d"
      Background="#0A0505"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InvertBool"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <Style x:Key="XbdmCard" TargetType="Border">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,16"/>
        </Style>
        <Style x:Key="ConsoleStat" TargetType="Border">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="BorderBrush" Value="#2A1010"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
        <Style x:Key="XbdmButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="BorderBrush" Value="#CC0000"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="XbdmRedButton" TargetType="Button" BasedOn="{StaticResource XbdmButton}">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="BorderBrush" Value="#FF0033"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Connection Bar -->
        <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                             Fill="{Binding ConnectionStatusColor}"/>
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding ConnectionStatusColor}" VerticalAlignment="Center"/>
                            <Border Background="#1A0505" BorderBrush="#CC0000" BorderThickness="1"
                                    CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="BETA" FontSize="9" FontWeight="Bold" Foreground="#CC0000"
                                           VerticalAlignment="Center"/>
                            </Border>
                </StackPanel>

                <!-- Console name/IP input -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="CONSOLE NAME / IP" FontSize="9" FontWeight="Bold"
                               Foreground="#CC0000" Margin="2,0,0,3"/>
                    <ui:TextBox Text="{Binding TargetConsole, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Console name or IP..."
                                Padding="10,8" FontSize="13" MinWidth="220"/>
                </StackPanel>

                <!-- Connect/Scan/Disconnect -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource XbdmRedButton}"
                            Content="⚡ Connect"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Command="{Binding ConnectCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource InvertBoolToVis}}"
                            Margin="0,0,4,0"/>
                    <Button Style="{StaticResource XbdmButton}"
                            Content="🔍 Scan"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Command="{Binding ScanNetworkCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource InvertBoolToVis}}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource XbdmButton}"
                            Content="Disconnect"
                            Command="{Binding DisconnectCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Discovered consoles dropdown -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsConnected, Converter={StaticResource InvertBoolToVis}}">
                    <ItemsControl ItemsSource="{Binding DiscoveredConsoles}"
                                  Margin="10,0,0,0" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel MaxHeight="200"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource XbdmButton}"
                                        Content="{Binding}"
                                        Command="{Binding DataContext.ConnectToDiscoveredCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,6,4"
                                        Padding="10,6"
                                        FontSize="11"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Console info chips (only show when connected) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                    <Border Style="{StaticResource ConsoleStat}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="NAME  " FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ConsoleName}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ConsoleStat}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="IP  " FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ConsoleIp}" FontSize="12" Foreground="#FF3333"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ConsoleStat}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="KERNEL  " FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding KernelVersion}" FontSize="12" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ConsoleStat}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TYPE  " FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ConsoleType}" FontSize="12" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ui:ProgressRing Grid.Column="4" Width="24" Height="24" IsIndeterminate="True"
                                  Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                  Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- Notice about 360 achievement unlocking -->
        <Border Grid.Row="1" Background="#1A0505" BorderBrush="#CC0000" BorderThickness="1" Padding="20,12" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Xbox 360 achievement unlocking coming in a future update. This page is mostly useless right now." 
                           FontSize="12" Foreground="#FF6666" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: File Browser -->
            <Border Grid.Column="0" Background="#090909" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <TextBlock Text="📁  FILE BROWSER" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource KrakenRedGlowBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TreeView Grid.Row="1" Background="Transparent" BorderThickness="0"
                              ItemsSource="{Binding DriveItems}" x:Name="FileTree">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Foreground" Value="#CCC"/>
                                <Setter Property="Padding" Value="4,3"/>
                                <EventSetter Event="Expanded" Handler="TreeItem_Expanded"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A0808"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                    <TextBlock Text="{Binding Icon}" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Size}" FontSize="10" Foreground="#555"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <Border Grid.Row="2" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0" Padding="12,10">
                        <WrapPanel>
                            <Button Style="{StaticResource XbdmRedButton}" Content="⬇ Download" Margin="0,0,6,4"
                                    IsEnabled="{Binding IsConnected}" Click="DownloadSelected_Click"/>
                            <Button Style="{StaticResource XbdmButton}" Content="⬆ Upload" Margin="0,0,6,4"
                                    IsEnabled="{Binding IsConnected}" Click="UploadToSelected_Click"/>
                            <Button Style="{StaticResource XbdmButton}" Content="🗑 Delete" Margin="0,0,0,4"
                                    IsEnabled="{Binding IsConnected}" Click="DeleteSelected_Click"/>
                        </WrapPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: Console Tools -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="20,16,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Console Control -->
                    <Border Grid.Row="0" Style="{StaticResource XbdmCard}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="CONSOLE CONTROL" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource KrakenRedGlowBrush}" Margin="0,0,0,14"/>
                            <WrapPanel Grid.Row="1">
                                <Button Style="{StaticResource XbdmButton}" Content="🔄 Cold Reboot" Margin="0,0,8,8"
                                        IsEnabled="{Binding IsConnected}" Command="{Binding RebootCommand}"/>
                                <Button Style="{StaticResource XbdmButton}" Content="♻️ Warm Reboot" Margin="0,0,8,8"
                                        IsEnabled="{Binding IsConnected}" Command="{Binding RebootWarmCommand}"/>
                                <Button Style="{StaticResource XbdmButton}" Content="▶ Resume" Margin="0,0,8,8"
                                        IsEnabled="{Binding IsConnected}" Click="GoConsole_Click"/>
                                <Button Style="{StaticResource XbdmButton}" Content="⏸ Freeze" Margin="0,0,8,8"
                                        IsEnabled="{Binding IsConnected}" Click="StopConsole_Click"/>
                                <Button Style="{StaticResource XbdmRedButton}" Content="📸 Screenshot" Margin="0,0,8,8"
                                        IsEnabled="{Binding IsConnected}" Command="{Binding TakeScreenshotCommand}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <!-- Running Title -->
                    <Border Grid.Row="1" Style="{StaticResource XbdmCard}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="RUNNING TITLE" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource KrakenRedGlowBrush}"/>
                                <Button Style="{StaticResource XbdmButton}" HorizontalAlignment="Right"
                                        Content="⟳ Refresh" Padding="10,4"
                                        IsEnabled="{Binding IsConnected}"
                                        Command="{Binding RefreshTitleCommand}"/>
                            </Grid>
                            <Border Grid.Row="1" Background="#111" CornerRadius="6" Padding="14,10">
                                <TextBlock Text="{Binding CurrentTitle}" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Achievements -->
                    <Border Grid.Row="2" Style="{StaticResource XbdmCard}" Margin="0,0,0,16"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="ACHIEVEMENTS" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource KrakenRedGlowBrush}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource XbdmButton}"
                                            Content="🔍 Scan Achievements" Padding="10,4"
                                            Margin="0,0,6,0"
                                            IsEnabled="{Binding IsAchievementBusy, Converter={StaticResource InvertBool}}"
                                            Command="{Binding ScanAchievementsCommand}"/>
                                    <Button Style="{StaticResource XbdmRedButton}"
                                            Content="★ Unlock All" Padding="10,4"
                                            IsEnabled="{Binding IsAchievementBusy, Converter={StaticResource InvertBool}}"
                                            Command="{Binding UnlockAllAchievementsCommand}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="1" Text="{Binding AchievementStatus}" FontSize="11"
                                       Foreground="#888" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="3" Margin="0,0,0,6"
                                         Visibility="{Binding IsAchievementBusy, Converter={StaticResource BoolToVis}}"
                                         Foreground="#CC0000" Background="#1A1A1A"/>

                            <ScrollViewer Grid.Row="3" MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Achievements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#111" BorderBrush="#2A2A2A" BorderThickness="1"
                                                    CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Status}"
                                                               FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="White"/>
                                                            <TextBlock Text="  +{Binding Gamerscore}G" FontSize="11"
                                                                       Foreground="#FF0033" Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                                   Foreground="#666" TextWrapping="Wrap"
                                                                   Visibility="{Binding Description, Converter={StaticResource NullToVis}}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Style="{StaticResource XbdmButton}"
                                                            Content="★ Unlock" Padding="8,4" FontSize="10"
                                                            IsEnabled="{Binding IsUnlocked, Converter={StaticResource InvertBool}}"
                                                            Command="{Binding DataContext.UnlockAchievementCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Raw Command -->
                    <Border Grid.Row="3" Style="{StaticResource XbdmCard}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="RAW COMMAND" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource KrakenRedGlowBrush}" Margin="0,0,0,12"/>
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <ui:TextBox x:Name="RawCommandBox"
                                            PlaceholderText="e.g. xbeinfo running, dirlist name=Hdd:\..."
                                            Padding="10,8" FontFamily="Consolas"
                                            KeyDown="RawCommand_KeyDown"
                                            Margin="0,0,90,0"/>
                                <Button Style="{StaticResource XbdmRedButton}"
                                        Content="Send" HorizontalAlignment="Right"
                                        Width="80" IsEnabled="{Binding IsConnected}"
                                        Click="SendRawCommand_Click"/>
                            </Grid>
                            <Border Grid.Row="2" Background="#0A0505" CornerRadius="6" Padding="12,8"
                                    BorderBrush="#1A1A1A" BorderThickness="1">
                                <TextBlock Text="{Binding StatusText}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#00FF88" TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Download Path -->
                    <Border Grid.Row="4" Style="{StaticResource XbdmCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="LOCAL SAVE PATH" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource KrakenRedGlowBrush}" Margin="0,0,0,10"/>
                            <Grid Grid.Row="1">
                                <ui:TextBox Text="{Binding LocalSavePath, Mode=TwoWay}" Padding="10,8" Margin="0,0,90,0"/>
                                <Button Style="{StaticResource XbdmButton}" Content="Browse"
                                        HorizontalAlignment="Right" Width="80" Click="BrowseSavePath_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="3" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0" Padding="20,8">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="11" FontFamily="Consolas"
                           Foreground="#888" VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="#444"
                           VerticalAlignment="Center" Text="xbdm.dll  ·  KrakenXboxUnlocker XBDM Bridge"/>
            </Grid>
        </Border>
    </Grid>
</Page>
