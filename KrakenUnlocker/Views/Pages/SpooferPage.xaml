<Page
    x:Class="KrakenUnlocker.Views.Pages.SpooferPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:KrakenUnlocker.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="SpooferPagen"
    Title="Spoofer Page"
    d:DataContext="{d:DesignInstance local:SpooferPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="700" d:DesignWidth="1100"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d"
    Background="#0A0505">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="MiscBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#CC0000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MiscRedBtn" TargetType="Button" BasedOn="{StaticResource MiscBtn}">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="BorderBrush" Value="#FF0033"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Art panel -->
        <Border Grid.Column="0" Background="#090909" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" ClipToBounds="True">
                    <ui:Image Source="{Binding ViewModel.GameImage}" Stretch="UniformToFill" ClipToBounds="True"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,14,14,14">
                        <TextBlock Text="CURRENTLY SPOOFING" FontSize="9" FontWeight="Bold"
                                   Foreground="#CC0000" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource InfoCard}" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="GAME" FontSize="9" Foreground="#555" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding ViewModel.GameName}" FontSize="12"
                                           Foreground="White" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCard}" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="TITLE ID" FontSize="9" Foreground="#555" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding ViewModel.GameTitleID}" FontSize="12" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource InfoCard}">
                            <StackPanel>
                                <TextBlock Text="PFN" FontSize="9" Foreground="#555" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding ViewModel.GamePFN}" FontSize="10"
                                           Foreground="#666" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Stats center -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">
                <TextBlock Text="GAME DETAILS" FontSize="10" FontWeight="Bold"
                           Foreground="#CC0000" Margin="0,0,0,16"/>
                <UniformGrid Columns="2">
                    <Border Style="{StaticResource InfoCard}" Margin="0,0,6,6">
                        <StackPanel>
                            <TextBlock Text="GAMERSCORE" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ViewModel.GameGamerscore}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoCard}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="TYPE" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ViewModel.GameType}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoCard}" Margin="0,0,6,6">
                        <StackPanel>
                            <TextBlock Text="GAME PASS" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ViewModel.GameGamepass}" FontSize="13" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoCard}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="DEVICES" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ViewModel.GameDevices}" FontSize="12" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoCard}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="PLAYTIME" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ViewModel.GameTime}" FontSize="13" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoCard}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="STATUS" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ViewModel.SpoofingText}" FontSize="12"
                                       Foreground="#FF3333" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <!-- Control panel -->
        <Border Grid.Column="2" Background="#090909" BorderBrush="#1A1A1A" BorderThickness="1,0,0,0">
            <StackPanel Margin="20,24,20,24">
                <TextBlock Text="SPOOF TITLE ID" FontSize="10" FontWeight="Bold"
                           Foreground="#CC0000" Margin="0,0,0,12"/>
                <ui:TextBox PlaceholderText="Enter Title ID..."
                            Text="{Binding ViewModel.NewSpoofingID, Mode=TwoWay}"
                            Padding="12,10" Margin="0,0,0,12"/>
                <Button Style="{StaticResource MiscRedBtn}"
                        Content="{Binding ViewModel.SpoofingButtonText, IsAsync=true}"
                        IsEnabled="{Binding ViewModel.IsInitialized}"
                        Command="{Binding ViewModel.SpooferButtonClickedCommand}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
