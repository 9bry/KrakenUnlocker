<Page
    x:Class="KrakenUnlocker.Views.Pages.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:KrakenUnlocker.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="QueuePage"
    d:DataContext="{d:DesignInstance local:QueuePage, IsDesignTimeCreatable=False}"
    d:DesignHeight="760" d:DesignWidth="1100"
    Background="#0A0505"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="QueueBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#CC0000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="QueueRedBtn" TargetType="Button" BasedOn="{StaticResource QueueBtn}">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="BorderBrush" Value="#FF0033"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Awesome Red Glow background -->
        <Border IsHitTestVisible="False" Opacity="0.15">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="#CC0000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- LEFT: Build panel -->
        <Border Grid.Column="0" Background="#090909" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <TextBlock Text="GAME QUEUE" FontSize="11" FontWeight="Bold"
                               Foreground="#CC0000" Margin="0,0,0,4"/>
                    <TextBlock Text="Build a queue of games and auto-unlock achievements in order."
                               FontSize="12" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Step 1: Find game -->
                    <Border Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                            CornerRadius="10" Padding="18,16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource StepBadge}">
                                    <TextBlock Text="1" FontSize="13" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Find a game" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid>
                                <ui:TextBox PlaceholderText="Search by game name…"
                                            IsEnabled="{Binding ViewModel.CanEdit}"
                                            Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,90,0" Padding="10,9">
                                    <ui:TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding ViewModel.SearchGamesCommand}"/>
                                    </ui:TextBox.InputBindings>
                                </ui:TextBox>
                                <Button Style="{StaticResource QueueRedBtn}" Content="Search"
                                        HorizontalAlignment="Right" Width="80"
                                        IsEnabled="{Binding ViewModel.CanEdit}"
                                        Command="{Binding ViewModel.SearchGamesCommand}"/>
                            </Grid>

                            <Border Background="#0A0505" CornerRadius="6" Margin="0,10,0,0"
                                    MaxHeight="180" BorderBrush="#1A1A1A" BorderThickness="1">
                                <ListView BorderThickness="0" Background="Transparent"
                                          ItemsSource="{Binding ViewModel.SearchResults}"
                                          SelectedItem="{Binding ViewModel.SelectedResult, Mode=TwoWay}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#111"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A0808"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#2A0808"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" FontSize="12" Foreground="#CCC"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Background="#1A0505" CornerRadius="3"
                                                        Padding="6,2" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding TitleId}" FontSize="10" Foreground="#FF3333"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Step 2: Reference gamertag -->
                    <Border Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                            CornerRadius="10" Padding="18,16" Margin="0,0,0,12"
                            Visibility="{Binding ViewModel.HasSelection, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource StepBadge}">
                                    <TextBlock Text="2" FontSize="13" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Mirror unlock order" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="{Binding ViewModel.DraftName}" FontSize="11" Foreground="#666"/>
                                </StackPanel>
                            </StackPanel>
                            <Grid>
                                <ui:TextBox PlaceholderText="Reference gamertag…"
                                            IsEnabled="{Binding ViewModel.CanEdit}"
                                            Text="{Binding ViewModel.DraftGamertag, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,110,0" Padding="10,9"/>
                                <Button Style="{StaticResource QueueRedBtn}" Content="⚡ Build"
                                        HorizontalAlignment="Right" Width="100"
                                        IsEnabled="{Binding ViewModel.CanEdit}"
                                        Command="{Binding ViewModel.BuildOrderCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Step 3: Review order -->
                    <Border Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                            CornerRadius="10" Padding="18,16" Margin="0,0,0,12"
                            Visibility="{Binding ViewModel.HasOrder, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource StepBadge}">
                                    <TextBlock Text="3" FontSize="13" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Unlock order" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="{Binding ViewModel.DraftSummary}" FontSize="11" Foreground="#666"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Background="#0A0505" CornerRadius="6" MaxHeight="220"
                                    BorderBrush="#1A1A1A" BorderThickness="1" Margin="0,0,0,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ViewModel.Preview}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="12,5" Opacity="{Binding NameOpacity}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding PositionText}"
                                                               FontSize="11" Foreground="#CC0000" FontWeight="Bold"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               FontSize="12" Foreground="#CCC"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="3" Padding="8,2">
                                                        <TextBlock Text="{Binding DelayText}" FontSize="10" Foreground="#666"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <WrapPanel>
                                <Button Style="{StaticResource QueueBtn}" Content="Edit Delays"
                                        IsEnabled="{Binding ViewModel.CanEdit}"
                                        Command="{Binding ViewModel.EditDraftDelaysCommand}"
                                        Margin="0,0,8,8"/>
                                <Button Style="{StaticResource QueueBtn}" Content="Skip List"
                                        IsEnabled="{Binding ViewModel.CanEdit}"
                                        Command="{Binding ViewModel.EditDraftSkipCommand}"
                                        Margin="0,0,8,8"/>
                                <Button Style="{StaticResource QueueRedBtn}" Content="+ Add to Queue"
                                        IsEnabled="{Binding ViewModel.CanEdit}"
                                        Command="{Binding ViewModel.ConfirmAddCommand}"
                                        Margin="0,0,8,8"/>
                                <Button Style="{StaticResource QueueBtn}" Content="Discard"
                                        Command="{Binding ViewModel.DiscardDraftCommand}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- RIGHT: Queue panel -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Controls bar -->
            <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#1A1A1A"
                    BorderThickness="0,0,0,1" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="QUEUE" FontSize="10" FontWeight="Bold" Foreground="#CC0000" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Delay between games:" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ui:TextBox Width="60" MaxLength="3" Padding="8,6" FontSize="13"
                                        IsEnabled="{Binding ViewModel.IsIdle}"
                                        Text="{Binding ViewModel.CooldownMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="min" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ViewModel.RunStatus}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#CCC" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding ViewModel.CooldownText}" FontSize="11" Foreground="#FF3333"/>
                        <TextBlock Text="{Binding ViewModel.QueueEtaText}" FontSize="11" Foreground="#555"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource QueueRedBtn}" Content="▶ Start Queue"
                                IsEnabled="{Binding ViewModel.IsIdle}"
                                Command="{Binding ViewModel.StartQueueCommand}"
                                Margin="0,0,8,0"/>
                        <Button Style="{StaticResource QueueBtn}" Content="⏹ Stop"
                                IsEnabled="{Binding ViewModel.IsRunning}"
                                Command="{Binding ViewModel.StopQueueCommand}"
                                Margin="0,0,8,0"/>
                        <Button Style="{StaticResource QueueBtn}" Content="🗑 Clear"
                                IsEnabled="{Binding ViewModel.IsIdle}"
                                Command="{Binding ViewModel.ClearQueueCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Queue items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ViewModel.Games}" Margin="20,16,20,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                                    CornerRadius="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left accent bar -->
                                    <Border Grid.Column="0" Background="#CC0000" CornerRadius="10,0,0,10"/>

                                    <!-- Game info -->
                                    <StackPanel Grid.Column="1" Margin="16,14,16,14" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameName}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding EstimateText}" FontSize="11" Foreground="#666" Margin="0,0,12,0"/>
                                            <TextBlock Text="👤 " FontSize="11"/>
                                            <TextBlock Text="{Binding Gamertag}" FontSize="11" Foreground="#555"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Status -->
                                    <Border Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0"
                                            Background="#1A0505" CornerRadius="4" Padding="10,4">
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding StatusColor}"/>
                                    </Border>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                                        <Button Style="{StaticResource QueueBtn}" Content="↑" Width="32" Height="32" Padding="0"
                                                ToolTip="Move up"
                                                Command="{Binding DataContext.ViewModel.MoveUpCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                        <Button Style="{StaticResource QueueBtn}" Content="↓" Width="32" Height="32" Padding="0"
                                                ToolTip="Move down"
                                                Command="{Binding DataContext.ViewModel.MoveDownCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                        <Button Style="{StaticResource QueueBtn}" Content="✕" Width="32" Height="32" Padding="0"
                                                ToolTip="Remove"
                                                Command="{Binding DataContext.ViewModel.RemoveCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
