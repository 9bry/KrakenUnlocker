<Page x:Class="KrakenUnlocker.Views.Pages.GamesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:KrakenUnlocker.Views.Pages"
      xmlns:controls="clr-namespace:KrakenUnlocker.Views.Controls"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
      Title="GamesPage"
      x:Name="GamesPagen"
      d:DataContext="{d:DesignInstance local:GamesPage, IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d"
      Background="#0A0505">

    <Grid Margin="28,16,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{Binding ViewModel.GamesListHeight}"/>
            <RowDefinition Height="{Binding ViewModel.LoadingHeight}"/>
        </Grid.RowDefinitions>

        <!-- Controls Section -->
        <Border Grid.Row="0" Style="{StaticResource KrakenCardBorder}" Margin="0,0,0,20" Padding="24,20" BorderBrush="#551111">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#220505" Offset="0"/>
                    <GradientStop Color="#1A0000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource KrakenStatLabel}" Text="PROFILE XUID" Margin="0,0,0,8"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="Load another Xbox profile's games" Margin="0,0,0,10"/>
                    <Grid>
                        <ui:TextBox x:Name="XUIDBox"
                                    IsEnabled="{Binding ViewModel.IsInitialized}"
                                    Padding="12,10"
                                    Margin="0,0,50,0"
                                    Text="{Binding ViewModel.XuidOverride, Mode=TwoWay}"
                                    BorderBrush="#CC0000">
                        </ui:TextBox>
                        <Button x:Name="RefreshButton"
                                   IsEnabled="{Binding ViewModel.IsInitialized}"
                                   HorizontalAlignment="Right"
                                   Width="44" Height="44"
                                   ToolTip="Load Profile"
                                   Command="{Binding ViewModel.GetGamesListCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#CC0000" CornerRadius="6">
                                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#FF0033"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#990000"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
                                            <Setter TargetName="bg" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0">
                    <TextBlock Style="{StaticResource KrakenStatLabel}" Text="SEARCH" Margin="0,0,0,8"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="{Binding ViewModel.SearchLabel}" Margin="0,0,0,10"/>
                    <Grid>
                        <ui:TextBox x:Name="SearchBox"
                                    IsEnabled="{Binding ViewModel.IsInitialized}"
                                    Padding="12,10"
                                    Margin="0,0,50,0"
                                    Text="{Binding ViewModel.SearchText, Mode=TwoWay, IsAsync=True}"
                                    KeyDown="SearchBox_OnKeyDown"
                                    BorderBrush="#CC0000">
                        </ui:TextBox>
                        <Button x:Name="SearchButton"
                                   IsEnabled="{Binding ViewModel.IsInitialized}"
                                   HorizontalAlignment="Right"
                                   Width="44" Height="44"
                                   ToolTip="Search"
                                   Command="{Binding ViewModel.SearchAndFilterGamesCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#CC0000" CornerRadius="6">
                                        <ui:SymbolIcon Symbol="Search24" FontSize="18" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#FF0033"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#990000"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
                                            <Setter TargetName="bg" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="12,0,0,0">
                    <TextBlock Style="{StaticResource KrakenStatLabel}" Text="FILTER" Margin="0,0,0,8"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="Select platform to display" Margin="0,0,0,10"/>
                    <ComboBox x:Name="FilterBox"
                              IsEnabled="{Binding ViewModel.IsInitialized}"
                              Padding="12,10"
                              ItemsSource="{Binding ViewModel.FilterOptions}"
                              SelectionChanged="FilterBox_OnSelectionChanged"
                              SelectedIndex="{Binding ViewModel.FilterIndex, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading State -->
        <Grid Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
            <controls:KrakenLoader StatusText="Loading your game library..."
                                   Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- Games Grid -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding ViewModel.Games}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.CacheLength="200"
                 VirtualizingPanel.CacheLengthUnit="Pixel"
                 PreviewMouseWheel="GamesList_PreviewMouseWheel">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <vwp:VirtualizingWrapPanel SpacingMode="None" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Game Card -->
                    <Border Margin="8,8" Width="190" Background="#0D0D0D" CornerRadius="8"
                            BorderBrush="#1A1A1A" BorderThickness="1" CacheMode="BitmapCache">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="4" Opacity="0.6"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Game Cover -->
                            <Button Grid.Row="0" Cursor="Hand" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    Tag="{Binding Index}"
                                    Click="ButtonBase_OnClick"
                                    MouseRightButtonDown="ButtonBase_RightClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="8,8,0,0" ClipToBounds="True" Height="190" Width="190">
                                            <Grid>
                                                <ui:Image Source="{Binding Image, IsAsync=true}" 
                                                          Stretch="UniformToFill"
                                                          Image.ImageFailed="Image_ImageFailed"/>
                                                <!-- Hover Overlay -->
                                                <Border Background="#AA000000" Opacity="0" x:Name="HoverOverlay">
                                                    <TextBlock Text="▶ VIEW" FontSize="18" FontWeight="Bold" 
                                                               Foreground="#FF0000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay" 
                                                                           Storyboard.TargetProperty="Opacity"
                                                                           To="1" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay" 
                                                                           Storyboard.TargetProperty="Opacity"
                                                                           To="0" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Achievement Progress Bar -->
                            <Border Grid.Row="1" Background="#0A0505" Height="36" BorderBrush="#1A1A1A" BorderThickness="0,1">
                                <Grid>
                                    <ProgressBar Value="{Binding Progress}" Height="36" BorderThickness="0"
                                                Background="#0A0505" Foreground="#CC0000"/>
                                    <Grid Margin="12,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="🏆" FontSize="13" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding CurrentAchievements}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Gamerscore}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="G" FontSize="11" Foreground="White" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Game Title -->
                            <Border Grid.Row="2" Padding="12,10" Background="#0D0D0D" CornerRadius="0,0,8,8">
                                <TextBlock Text="{Binding Title}" FontSize="12" Foreground="White" 
                                          TextAlignment="Center" TextWrapping="Wrap" 
                                          MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>






