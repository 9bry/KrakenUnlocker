<Page
    x:Class="KrakenUnlocker.Views.Pages.MiscPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:KrakenUnlocker.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="MiscPagen"
    Title="Misc Page"
    d:DataContext="{d:DesignInstance local:MiscPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="700" d:DesignWidth="1100"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d"
    Background="#0A0505">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="MiscBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#CC0000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MiscRedBtn" TargetType="Button" BasedOn="{StaticResource MiscBtn}">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="BorderBrush" Value="#FF0033"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
    </Page.Resources>

    <TabControl>

        <!-- ══ TITLE ID SEARCH ══════════════════════════════════════════════════ -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Margin="0,0,6,0" Symbol="Search24"/>
                    <TextBlock Text="Title ID Search"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: search + results -->
                <Border Grid.Column="0" Background="#090909" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Search input -->
                        <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#1A1A1A"
                                BorderThickness="0,0,0,1" Padding="16,14">
                            <Grid MaxWidth="400" HorizontalAlignment="Left">
                                <ui:TextBox x:Name="TitleIdSearchBox"
                                            Text="{Binding ViewModel.TSearchText, Mode=TwoWay}"
                                            PlaceholderText="Search game name..."
                                            Padding="10,9" Margin="0,0,82,0"
                                            KeyDown="TitleIDSearch_OnKeyDown"/>
                                <Button Style="{StaticResource MiscRedBtn}" Content="Search"
                                        HorizontalAlignment="Right" Width="74"
                                        Command="{Binding ViewModel.SearchGameCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Results -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#111" Padding="16,10"
                                    BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                                <TextBlock Text="RESULTS" FontSize="9" FontWeight="Bold" Foreground="#CC0000"/>
                            </Border>
                            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0"
                                     ItemsSource="{Binding ViewModel.TSearchTitleNames}"
                                     SelectionChanged="Selector_OnSelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="16,10"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#111"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A0808"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2A0808"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="13" Foreground="#CCC" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Right: details -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,28,32,28">
                        <TextBlock Text="GAME DETAILS" FontSize="10" FontWeight="Bold"
                                   Foreground="#CC0000" Margin="0,0,0,20"/>
                        <TextBlock Text="{Binding ViewModel.TSearchGameName}" FontSize="22" FontWeight="Black"
                                   Foreground="White" TextWrapping="Wrap" Margin="0,0,0,24"/>
                        <Border Style="{StaticResource InfoCard}" Margin="0,0,0,10" Padding="16,14">
                            <Grid>
                                <TextBlock Text="TITLE ID" FontSize="10" Foreground="#555" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding ViewModel.TSearchGameTitleID}"
                                               FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,8,0"/>
                                    <Button Content="📋" ToolTip="Copy Title ID" Cursor="Hand" Padding="4,0"
                                            Background="Transparent" BorderThickness="0" Foreground="#666"
                                            Click="CopyTitleIdFromSearch_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource InfoCard}" Padding="16,14">
                            <Grid>
                                <TextBlock Text="TITLE BASED" FontSize="10" Foreground="#555" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ViewModel.TSearchGameTitleBased}" HorizontalAlignment="Right"
                                           FontSize="14" Foreground="White"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <!-- ══ GAMERTAG SEARCH ══════════════════════════════════════════════════ -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Margin="0,0,6,0" Symbol="Person24"/>
                    <TextBlock Text="Gamertag Search"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#1A1A1A"
                        BorderThickness="0,0,0,1" Padding="24,14">
                    <Grid MaxWidth="800" HorizontalAlignment="Stretch">
                        <ui:TextBox x:Name="GamertagSearchBox"
                                    Text="{Binding ViewModel.Gamertag, Mode=TwoWay}"
                                    PlaceholderText="Enter Gamertag..."
                                    Padding="16,14" FontSize="16"
                                    Margin="0,0,130,0"
                                    KeyDown="GamertagSearch_OnKeyDown"/>
                        <Button Style="{StaticResource MiscRedBtn}" Content="Search"
                                HorizontalAlignment="Right" Width="120"
                                IsEnabled="{Binding ViewModel.IsInitialized}"
                                Command="{Binding ViewModel.SearchGamertagCommand}"/>
                    </Grid>
                </Border>

                <!-- Profile result -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: avatar + basic info -->
                    <Border Grid.Column="0" Background="#090909" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
                        <StackPanel Margin="24,28,24,24">
                            <!-- Avatar -->
                            <Grid Width="110" Height="110" Margin="0,0,0,20" HorizontalAlignment="Left">
                                <Ellipse Width="110" Height="110" Fill="#CC0000">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#FF0033" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Ellipse Width="104" Height="104" Fill="#0D0D0D"/>
                                <Ellipse Width="98" Height="98">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding ViewModel.GamertagImage}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Width="104" Height="104" Stroke="#CC0000" StrokeThickness="2" Fill="Transparent"/>
                            </Grid>
                            <TextBlock Text="{Binding ViewModel.GamertagName}" FontSize="20" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ViewModel.GamertagXuid}" FontSize="11"
                                       Foreground="#444" Margin="0,0,0,20" TextWrapping="Wrap"/>
                            <Border Style="{StaticResource InfoCard}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="GAMERSCORE" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ViewModel.GamertagScore}"
                                               FontSize="18" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource MiscBtn}" Content="📄  Export to CSV"
                                    IsEnabled="{Binding ViewModel.IsInitialized}"
                                    Click="ExportToCsvButton_Click"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,16"/>
                            <CheckBox Content="Exclude 0G Games" FontSize="12" Foreground="#777" Margin="0,0,0,8"
                                      IsChecked="{Binding ViewModel.ExcludeZeroGamerscoreGames, Mode=TwoWay}"/>
                            <CheckBox Content="Exclude Xbox 360" FontSize="12" Foreground="#777"
                                      IsChecked="{Binding ViewModel.ExcludeXbox360Games, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <!-- Right: game list -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#1A1A1A"
                                BorderThickness="0,0,0,1" Padding="20,12">
                            <Grid>
                                <TextBlock Text="GAME LIBRARY" FontSize="10" FontWeight="Bold"
                                           Foreground="#CC0000" VerticalAlignment="Center"/>
                                <ui:ProgressRing Grid.Column="0" Width="18" Height="18" IsIndeterminate="True"
                                                 HorizontalAlignment="Right"
                                                 Visibility="{Binding ViewModel.IsLoadingGames, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1" x:Name="GamesGrid"
                                  ItemsSource="{Binding ViewModel.GamertagGames}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  RowBackground="#0D0D0D" AlternatingRowBackground="#111"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  RowHeight="46" FontSize="12"
                                  CanUserSortColumns="True"
                                  VerticalScrollBarVisibility="Visible">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📋  Copy Title ID" Click="CopyTitleId_Click"/>
                                    <MenuItem Header="🎮  Copy Title Name" Click="CopyTitleName_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#0A0A0A"/>
                                    <Setter Property="Foreground" Value="#CC0000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#CCC"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1A0505"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="*" MinWidth="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,0,0,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="TITLE ID" Binding="{Binding TitleId}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF3333"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="GS" Binding="{Binding Gamerscore}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#CCC"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="%" Binding="{Binding Progress}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#888"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="DEVICES" Binding="{Binding Devices}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#555"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
