<Page x:Class="KrakenUnlocker.Views.Pages.InfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:KrakenUnlocker.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="InfoPage"
      d:DataContext="{d:DesignInstance local:InfoPage, IsDesignTimeCreatable=False}"
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#0A0505"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InvertBool"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
        <!-- Local button style -->
        <Style x:Key="SocialBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderBrush" Value="#CC0000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#CC0000"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#FF0033"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#990000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoStatBorder" TargetType="Border">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="BorderBrush" Value="#2A1010"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,20,28,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Hero Banner -->
            <Border Grid.Row="0" Margin="0,0,0,20" CornerRadius="14"
                    Background="#0D0D0D" BorderBrush="#CC0000" BorderThickness="4,1,1,1">
                <Border.Effect>
                    <DropShadowEffect Color="#FF0033" BlurRadius="40" ShadowDepth="0" Opacity="0.4"/>
                </Border.Effect>
                <Grid>
                    <Grid Margin="28,28,28,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- App icon - no border, red glow, big -->
                        <Grid Grid.Column="0" Width="80" Height="80" Margin="0,0,24,0">
                            <Image Source="/Assets/retro360.ico" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Effect>
                                    <DropShadowEffect Color="#FF0033" BlurRadius="22" ShadowDepth="0" Opacity="1"/>
                                </Image.Effect>
                            </Image>
                        </Grid>

                        <!-- Title block -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Border Background="#0A0505" BorderBrush="#2A2A2A" BorderThickness="1"
                                    CornerRadius="4" Padding="8,3" Margin="0,0,0,8" HorizontalAlignment="Left">
                                <TextBlock Text="ACHIEVEMENT HUNTER TOOLKIT" FontSize="9" FontWeight="Bold" Foreground="#555"/>
                            </Border>
                            <TextBlock Text="Kraken Xbox Unlocker" FontSize="28" FontWeight="Black"
                                       Foreground="White"/>
                            <TextBlock Text="Built for hunters. Not affiliated with Microsoft or Xbox."
                                       FontSize="12" Foreground="#666" Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- Version badge -->
                        <Border Grid.Column="2" VerticalAlignment="Center"
                                Background="#1A0505" BorderBrush="#CC0000" BorderThickness="1"
                                CornerRadius="8" Padding="16,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="v1.0" FontSize="22" FontWeight="Black"
                                           Foreground="#FF0033" HorizontalAlignment="Center"/>
                                <TextBlock Text="STABLE" FontSize="9" FontWeight="Bold"
                                           Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Creator Card - moved up for easier access -->
            <Border Grid.Row="1" Margin="0,0,0,16" CornerRadius="12"
                    Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1" Padding="28,22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="DEVELOPER" FontSize="10" FontWeight="Bold"
                               Foreground="#CC0000" Margin="0,0,0,16"/>

                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Grid Width="56" Height="56" Margin="0,0,18,0">
                            <Ellipse Width="56" Height="56" Fill="#CC0000">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF0033" BlurRadius="35" ShadowDepth="0" Opacity="1"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Width="50" Height="50" Fill="#0D0D0D"/>
                            <TextBlock Text="B" FontSize="24" FontWeight="Black" Foreground="#FF0033"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Bry" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Grid>

                    <!-- Social links with real logos -->
                    <WrapPanel Grid.Row="2">
                        <!-- Discord -->
                        <Button Style="{StaticResource SocialBtn}"
                                Command="{Binding ViewModel.OpenDiscordUrlCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#5865F2" Data="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.001.022.015.043.032.055a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Discord" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Telegram -->
                        <Button Style="{StaticResource SocialBtn}"
                                Command="{Binding ViewModel.OpenTelegramUrlCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#2CA5E0" Data="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Telegram" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- GitHub -->
                        <Button Style="{StaticResource SocialBtn}"
                                Command="{Binding ViewModel.OpenGithubUserUrlCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="White" Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="GitHub" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Instagram -->
                        <Button Style="{StaticResource SocialBtn}"
                                Command="{Binding ViewModel.OpenInstagramUrlCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,8,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#E1306C" Data="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Instagram @nipp" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- License / Subscription -->
            <Border Grid.Row="2" CornerRadius="12"
                    Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1" Padding="28,22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: status + login -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="LICENSE" FontSize="10" FontWeight="Bold"
                                   Foreground="#CC0000" Margin="0,0,0,4"/>
                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,0,8" BorderThickness="1" MaxWidth="400" HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A0505"/>
                                    <Setter Property="BorderBrush" Value="#CC0000"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseVM.RestoreIsError}" Value="False">
                                            <Setter Property="Background" Value="#0D1A0D"/>
                                            <Setter Property="BorderBrush" Value="#00AA44"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding LicenseVM.RestoreStatus}" FontSize="10"
                                       Foreground="#999" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Logged in view -->
                        <StackPanel Visibility="{Binding LicenseVM.IsPremium, Converter={StaticResource BoolToVis}}">
                            <Border Background="#0A1A0A" BorderBrush="#00AA44" BorderThickness="1"
                                    CornerRadius="8" Padding="16,12" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="✓" FontSize="16" Foreground="#00AA44" Margin="0,0,8,0"/>
                                        <TextBlock Text="PREMIUM ACTIVE" FontSize="11" FontWeight="Bold"
                                                   Foreground="#00AA44" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding LicenseVM.CurrentEmail}" FontSize="13"
                                               Foreground="White" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding LicenseVM.ExpiresText}" FontSize="11"
                                                   Foreground="#666"/>
                                        <TextBlock Text="{Binding LicenseVM.SessionCountdown}" FontSize="11"
                                                   Foreground="#999" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Days left badge -->
                            <Border Background="#1A0505" BorderBrush="#CC0000" BorderThickness="1"
                                    CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏳" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="SUBSCRIPTION" FontSize="9" FontWeight="Bold" Foreground="#555"/>
                                        <TextBlock Text="{Binding LicenseVM.DaysLeftText}" FontSize="14"
                                                   FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Button Content="Sign Out" Cursor="Hand"
                                    Command="{Binding LicenseVM.LogoutCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="#1A1A1A" CornerRadius="6"
                                                BorderBrush="#2A2A2A" BorderThickness="1" Padding="16,8">
                                            <TextBlock Text="{TemplateBinding Content}" FontSize="12"
                                                       Foreground="#888" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#CC0000"/>
                                                <Setter TargetName="bg" Property="BorderBrush" Value="#CC0000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Login view -->
                        <StackPanel Visibility="{Binding LicenseVM.ShowLogin, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Enter your email to sign in" FontSize="12"
                                       Foreground="#666" Margin="0,0,0,12"/>

                            <ui:TextBox PlaceholderText="your@email.com"
                                        Text="{Binding LicenseVM.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10,7" Margin="0,0,0,8" MaxWidth="320" HorizontalAlignment="Left"
                                        IsEnabled="{Binding LicenseVM.IsBusy, Converter={StaticResource InvertBool}}"/>

                            <!-- Code box - only shows after code sent -->
                            <ui:TextBox PlaceholderText="6-digit code"
                                        Text="{Binding LicenseVM.Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="10,7" Margin="0,0,0,10" MaxWidth="320" HorizontalAlignment="Left"
                                        IsEnabled="{Binding LicenseVM.CodeSent}"
                                        Visibility="{Binding LicenseVM.CodeSent, Converter={StaticResource BoolToVis}}"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Send Code" Margin="0,0,8,0" Cursor="Hand"
                                        Command="{Binding LicenseVM.SendCodeCommand}"
                                        Visibility="{Binding LicenseVM.CodeSent, Converter={StaticResource InvertBoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="#CC0000" CornerRadius="6" Padding="16,10">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#FF0033"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="Verify Code" Cursor="Hand"
                                        Command="{Binding LicenseVM.VerifyCodeCommand}"
                                        Visibility="{Binding LicenseVM.CodeSent, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="#CC0000" CornerRadius="6" Padding="16,10">
                                                <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                                           FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#FF0033"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <TextBlock Text="{Binding LicenseVM.StatusText}" FontSize="12"
                                       Foreground="#FF3333" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Busy indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                    Visibility="{Binding LicenseVM.IsBusy, Converter={StaticResource BoolToVis}}">
                            <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True" Margin="0,0,8,0"/>
                            <TextBlock Text="Please wait..." FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right: plan info + buy -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="SUBSCRIPTION" FontSize="10" FontWeight="Bold"
                                   Foreground="#CC0000" Margin="0,0,0,16"/>

                        <!-- Free tier -->
                        <Border Margin="0,0,0,10" CornerRadius="8" Padding="14,12" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#111"/>
                                    <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseVM.IsPremium}" Value="False">
                                            <Setter Property="Background" Value="#0A1A0A"/>
                                            <Setter Property="BorderBrush" Value="#1A3A1A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="FREE" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <Border Background="#1A1A1A" CornerRadius="4" Padding="8,2" Margin="8,0,0,0"
                                            Visibility="{Binding LicenseVM.IsPremium, Converter={StaticResource InvertBoolToVis}}">
                                        <TextBlock Text="CURRENT" FontSize="9" FontWeight="Bold" Foreground="#888"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="• Games browser" FontSize="12" Foreground="#888" Margin="0,3,0,0"/>
                                <TextBlock Text="• Title ID tools" FontSize="12" Foreground="#888" Margin="0,3,0,0"/>
                                <TextBlock Text="• Gamertag search" FontSize="12" Foreground="#888" Margin="0,3,0,0"/>
                                <TextBlock Text="• Manual unlock" FontSize="12" Foreground="#888" Margin="0,3,0,0"/>
                                <TextBlock Text="• Presence spoofer" FontSize="12" Foreground="#888" Margin="0,3,0,0"/>
                                <TextBlock Text="• Stats editor" FontSize="12" Foreground="#888" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Premium tier -->
                        <Border Margin="0,0,0,14" CornerRadius="8" Padding="14,12" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#111"/>
                                    <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseVM.IsPremium}" Value="True">
                                            <Setter Property="Background" Value="#1A0505"/>
                                            <Setter Property="BorderBrush" Value="#CC0000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="PREMIUM" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <Border Background="#3A1010" CornerRadius="4" Padding="8,2" Margin="8,0,0,0"
                                            Visibility="{Binding LicenseVM.IsPremium, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="CURRENT" FontSize="9" FontWeight="Bold" Foreground="#CC0000"/>
                                    </Border>
                                    <Border Background="#2A2A2A" CornerRadius="4" Padding="8,2" Margin="8,0,0,0"
                                            Visibility="{Binding LicenseVM.IsPremium, Converter={StaticResource InvertBoolToVis}}">
                                        <TextBlock Text="KO-FI" FontSize="9" FontWeight="Bold" Foreground="#666"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="• Everything in Free" FontSize="12" Foreground="#888" Margin="0,3,0,0"/>
                                <TextBlock Text="• Auto Unlocker with timer" FontSize="12" Foreground="White" Margin="0,3,0,0" FontWeight="SemiBold"/>
                                <TextBlock Text="• Game Queue" FontSize="12" Foreground="White" Margin="0,3,0,0" FontWeight="SemiBold"/>
