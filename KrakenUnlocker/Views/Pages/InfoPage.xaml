                        <TextBlock Text="After purchase, go to the Info tab → scroll to License → enter your Ko-fi email to activate."
                                   FontSize="10" Foreground="#444" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

