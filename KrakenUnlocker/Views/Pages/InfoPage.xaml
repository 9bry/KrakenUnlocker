                        <Button Cursor="Hand"
                                Command="{Binding LicenseVM.OpenKofiCommand}"
                                HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#CC0000" CornerRadius="6" Padding="16,12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF0033" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                        </Border.Effect>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="☕" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
