<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- EPIC CYBERPUNK OPENING ANIMATIONS -->

    <!-- Matrix Code Rain Opening -->
    <Storyboard x:Key="EpicOpeningSequence">
        <!-- Phase 1: Matrix Code Rain (0-2 seconds) -->
        <StringAnimationUsingKeyFrames Storyboard.TargetName="OpeningText" Storyboard.TargetProperty="Text" BeginTime="0:0:0">
            <DiscreteStringKeyFrame Value="01010101010101" KeyTime="0:0:0.1"/>
            <DiscreteStringKeyFrame Value="11001100110011" KeyTime="0:0:0.2"/>
            <DiscreteStringKeyFrame Value="10101010101010" KeyTime="0:0:0.3"/>
            <DiscreteStringKeyFrame Value="01110111011101" KeyTime="0:0:0.4"/>
            <DiscreteStringKeyFrame Value="11110000111100" KeyTime="0:0:0.5"/>
            <DiscreteStringKeyFrame Value="00110011001100" KeyTime="0:0:0.6"/>
            <DiscreteStringKeyFrame Value="INITIALIZING..." KeyTime="0:0:0.8"/>
            <DiscreteStringKeyFrame Value="KRAKEN PROTOCOL" KeyTime="0:0:1.2"/>
            <DiscreteStringKeyFrame Value="SYSTEM BREACH..." KeyTime="0:0:1.6"/>
            <DiscreteStringKeyFrame Value="ACCESS GRANTED" KeyTime="0:0:2.0"/>
        </StringAnimationUsingKeyFrames>

        <!-- Phase 2: Screen Glitch Effect (2-2.5 seconds) -->
        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlitchOverlay" Storyboard.TargetProperty="Opacity" BeginTime="0:0:2">
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
            <LinearDoubleKeyFrame Value="0.8" KeyTime="0:0:0.1"/>
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.2"/>
            <LinearDoubleKeyFrame Value="0.9" KeyTime="0:0:0.3"/>
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.4"/>
            <LinearDoubleKeyFrame Value="0.7" KeyTime="0:0:0.45"/>
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.5"/>
        </DoubleAnimationUsingKeyFrames>

        <!-- Phase 3: Hacker Terminal Bootup (2.5-4 seconds) -->
        <StringAnimationUsingKeyFrames Storyboard.TargetName="TerminalText" Storyboard.TargetProperty="Text" BeginTime="0:0:2.5">
            <DiscreteStringKeyFrame Value=">" KeyTime="0:0:0"/>
            <DiscreteStringKeyFrame Value="> Loading KRAKEN.EXE" KeyTime="0:0:0.3"/>
            <DiscreteStringKeyFrame Value="> Loading KRAKEN.EXE." KeyTime="0:0:0.6"/>
            <DiscreteStringKeyFrame Value="> Loading KRAKEN.EXE.." KeyTime="0:0:0.9"/>
            <DiscreteStringKeyFrame Value="> Loading KRAKEN.EXE..." KeyTime="0:0:1.2"/>
            <DiscreteStringKeyFrame Value="> XBOX API BYPASS: SUCCESS" KeyTime="0:0:1.5"/>
        </StringAnimationUsingKeyFrames>

        <!-- Phase 4: Epic Logo Slam (4-5 seconds) -->
        <DoubleAnimation Storyboard.TargetName="KrakenLogo" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                        From="0" To="1.2" Duration="0:0:0.8" BeginTime="0:0:4">
            <DoubleAnimation.EasingFunction>
                <BackEase EasingMode="EaseOut" Amplitude="0.8"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetName="KrakenLogo" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                        From="0" To="1.2" Duration="0:0:0.8" BeginTime="0:0:4">
            <DoubleAnimation.EasingFunction>
                <BackEase EasingMode="EaseOut" Amplitude="0.8"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>

        <!-- Scale back to normal -->
        <DoubleAnimation Storyboard.TargetName="KrakenLogo" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                        From="1.2" To="1" Duration="0:0:0.2" BeginTime="0:0:4.8"/>
        <DoubleAnimation Storyboard.TargetName="KrakenLogo" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                        From="1.2" To="1" Duration="0:0:0.2" BeginTime="0:0:4.8"/>

        <!-- Phase 5: Main Interface Slide In (5-6 seconds) -->
        <DoubleAnimation Storyboard.TargetName="OpeningScreen" Storyboard.TargetProperty="Opacity"
                        From="1" To="0" Duration="0:0:0.5" BeginTime="0:0:5"/>
        <DoubleAnimation Storyboard.TargetName="MainInterface" Storyboard.TargetProperty="Opacity"
                        From="0" To="1" Duration="0:0:1" BeginTime="0:0:5.2"/>

        <!-- Slide in from left -->
        <DoubleAnimation Storyboard.TargetName="MainInterface" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                        From="-1200" To="0" Duration="0:0:1" BeginTime="0:0:5.2">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Continuous Background Animations -->
    <Storyboard x:Key="ContinuousBackgroundEffects" RepeatBehavior="Forever">
        <!-- Rotating Hexagons -->
        <DoubleAnimation Storyboard.TargetName="HexagonPattern" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                        From="0" To="360" Duration="0:0:30"/>
        
        <!-- Pulsing Circuit Lines -->
        <DoubleAnimation Storyboard.TargetName="CircuitLines" Storyboard.TargetProperty="Opacity"
                        From="0.1" To="0.3" Duration="0:0:4" AutoReverse="True"/>

        <!-- Matrix Rain Drops -->
        <DoubleAnimation Storyboard.TargetName="MatrixRain1" Storyboard.TargetProperty="(Canvas.Top)"
                        From="-50" To="800" Duration="0:0:3"/>
        <DoubleAnimation Storyboard.TargetName="MatrixRain2" Storyboard.TargetProperty="(Canvas.Top)"
                        From="-50" To="800" Duration="0:0:4" BeginTime="0:0:1"/>
        <DoubleAnimation Storyboard.TargetName="MatrixRain3" Storyboard.TargetProperty="(Canvas.Top)"
                        From="-50" To="800" Duration="0:0:2.5" BeginTime="0:0:0.5"/>
    </Storyboard>

    <!-- Button Hover Animations -->
    <Storyboard x:Key="ButtonHoverGlow">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                        From="15" To="30" Duration="0:0:0.2"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                        From="0.8" To="1.5" Duration="0:0:0.2"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                        From="1" To="1.05" Duration="0:0:0.2"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                        From="1" To="1.05" Duration="0:0:0.2"/>
    </Storyboard>

    <!-- Glitch Text Animation -->
    <Storyboard x:Key="GlitchTextEffect" RepeatBehavior="Forever">
        <!-- Random glitch every 10 seconds -->
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" BeginTime="0:0:10">
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
            <LinearDoubleKeyFrame Value="3" KeyTime="0:0:0.05"/>
            <LinearDoubleKeyFrame Value="-2" KeyTime="0:0:0.1"/>
            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.15"/>
            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.2"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity" BeginTime="0:0:10">
            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0"/>
            <LinearDoubleKeyFrame Value="0.7" KeyTime="0:0:0.05"/>
            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.1"/>
            <LinearDoubleKeyFrame Value="0.9" KeyTime="0:0:0.15"/>
            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0.2"/>
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Cyber Loading Ring Animation -->
    <Storyboard x:Key="CyberLoadingRing" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                        From="0" To="360" Duration="0:0:1"/>
    </Storyboard>

    <!-- Screen Scan Line -->
    <Storyboard x:Key="ScreenScanLine" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)"
                        From="-5" To="800" Duration="0:0:4"/>
    </Storyboard>

    <!-- Epic Page Transition -->
    <Storyboard x:Key="PageTransitionSlideIn">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                        From="400" To="0" Duration="0:0:0.6">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                        From="0" To="1" Duration="0:0:0.6"/>
    </Storyboard>

    <!-- Data Stream Animation -->
    <Storyboard x:Key="DataStreamEffect" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)"
                        From="-100" To="1200" Duration="0:0:2"/>
    </Storyboard>

</ResourceDictionary>