<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- EVIL RED NEON GAMING THEME -->
    
    <!-- Base Colors -->
    <Color x:Key="EvilRed">#CC0000</Color>
    <Color x:Key="BrightRed">#FF3333</Color>
    <Color x:Key="DarkRed">#990000</Color>
    <Color x:Key="NeonRed">#FF6666</Color>
    <Color x:Key="CyberBlack">#0D0D0D</Color>
    <Color x:Key="DeepGrey">#1A1A1A</Color>
    <Color x:Key="MetalGrey">#2A2A2A</Color>
    <Color x:Key="GlowWhite">#FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="EvilRedBrush" Color="{StaticResource EvilRed}"/>
    <SolidColorBrush x:Key="BrightRedBrush" Color="{StaticResource BrightRed}"/>
    <SolidColorBrush x:Key="CyberBlackBrush" Color="{StaticResource CyberBlack}"/>
    <SolidColorBrush x:Key="DeepGreyBrush" Color="{StaticResource DeepGrey}"/>
    <SolidColorBrush x:Key="MetalGreyBrush" Color="{StaticResource MetalGrey}"/>

    <!-- Evil Gradients -->
    <LinearGradientBrush x:Key="EvilBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource CyberBlack}" Offset="0"/>
        <GradientStop Color="{StaticResource DeepGrey}" Offset="0.3"/>
        <GradientStop Color="{StaticResource MetalGrey}" Offset="0.7"/>
        <GradientStop Color="{StaticResource DeepGrey}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="EvilButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource EvilRed}" Offset="0"/>
        <GradientStop Color="{StaticResource DarkRed}" Offset="0.5"/>
        <GradientStop Color="{StaticResource EvilRed}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="EvilRedGlowGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource EvilRed}" Offset="0"/>
        <GradientStop Color="{StaticResource BrightRed}" Offset="0.5"/>
        <GradientStop Color="{StaticResource NeonRed}" Offset="1"/>
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="HexagonGlowBrush" Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="{StaticResource BrightRed}" Offset="0"/>
        <GradientStop Color="{StaticResource EvilRed}" Offset="0.7"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </RadialGradientBrush>

    <!-- Matrix Pattern Brush -->
    <DrawingBrush x:Key="MatrixPatternBrush" TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource EvilRed}" Geometry="M 0,0 L 2,0 L 2,2 L 0,2 Z"/>
                <GeometryDrawing Brush="{StaticResource BrightRed}" Geometry="M 10,10 L 12,10 L 12,12 L 10,12 Z"/>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Hexagon Pattern Brush -->
    <DrawingBrush x:Key="HexPatternBrush" TileMode="Tile" Viewport="0,0,50,50" ViewportUnits="Absolute" Opacity="0.1">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="{StaticResource BrightRed}">
                <GeometryDrawing.Geometry>
                    <PathGeometry>
                        <PathFigure StartPoint="25,5" IsClosed="True">
                            <LineSegment Point="40,15"/>
                            <LineSegment Point="40,35"/>
                            <LineSegment Point="25,45"/>
                            <LineSegment Point="10,35"/>
                            <LineSegment Point="10,15"/>
                        </PathFigure>
                    </PathGeometry>
                </GeometryDrawing.Geometry>
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource EvilRed}" Thickness="1"/>
                </GeometryDrawing.Pen>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Circuit Board Pattern -->
    <DrawingBrush x:Key="CircuitBrush" TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute" Opacity="0.15">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Horizontal line -->
                <GeometryDrawing Brush="{StaticResource EvilRed}" Geometry="M 0,20 L 40,20" />
                <!-- Vertical line -->
                <GeometryDrawing Brush="{StaticResource EvilRed}" Geometry="M 20,0 L 20,40" />
                <!-- Corner dots -->
                <GeometryDrawing Brush="{StaticResource BrightRed}" Geometry="M 18,18 L 22,18 L 22,22 L 18,22 Z"/>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Animated Scanning Line -->
    <LinearGradientBrush x:Key="ScanLineBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="Transparent" Offset="0"/>
        <GradientStop Color="{StaticResource BrightRed}" Offset="0.5"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>