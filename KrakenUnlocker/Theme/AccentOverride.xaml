<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Override every WPF-UI accent/blue key to red -->
    <!-- These must load AFTER ui:ControlsDictionary to win -->

    <Color x:Key="SystemAccentColor">#CC0000</Color>
    <Color x:Key="SystemAccentColorDark1">#AA0000</Color>
    <Color x:Key="SystemAccentColorDark2">#880000</Color>
    <Color x:Key="SystemAccentColorDark3">#660000</Color>
    <Color x:Key="SystemAccentColorLight1">#DD1111</Color>
    <Color x:Key="SystemAccentColorLight2">#FF0033</Color>
    <Color x:Key="SystemAccentColorLight3">#FF3355</Color>

    <SolidColorBrush x:Key="SystemAccentBrush"                      Color="#CC0000"/>
    <SolidColorBrush x:Key="SystemAccentBrushDark1"                  Color="#AA0000"/>
    <SolidColorBrush x:Key="SystemAccentBrushDark2"                  Color="#880000"/>
    <SolidColorBrush x:Key="SystemAccentBrushLight1"                 Color="#DD1111"/>
    <SolidColorBrush x:Key="SystemAccentBrushLight2"                 Color="#FF0033"/>
    <SolidColorBrush x:Key="SystemAccentBrushLight3"                 Color="#FF3355"/>

    <!-- TextBox focus underline / border -->
    <SolidColorBrush x:Key="TextControlBorderBrush"                  Color="#CC0000"/>
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"       Color="#FF0033"/>
    <SolidColorBrush x:Key="TextControlBorderBrushFocused"           Color="#FF0033"/>
    <SolidColorBrush x:Key="TextControlFocusedBorderBrush"           Color="#FF0033"/>

    <!-- Accent fill used for buttons, toggles, progress -->
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"             Color="#CC0000"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"           Color="#FF0033"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"            Color="#AA0000"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush"            Color="#3A1010"/>
    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush"         Color="#FF3344"/>
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush"       Color="#FF0033"/>
    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush"        Color="#CC0000"/>
    <SolidColorBrush x:Key="AccentTextFillColorDisabledBrush"        Color="#3A1010"/>

    <!-- Used by ToggleSwitch, RadioButton, CheckBox thumb -->
    <SolidColorBrush x:Key="ControlFillColorOnAccentDefaultBrush"    Color="#CC0000"/>
    <SolidColorBrush x:Key="ControlFillColorOnAccentSecondaryBrush"  Color="#FF0033"/>

    <!-- System accent colors (WPF-UI older naming) -->
    <SolidColorBrush x:Key="SystemAccentColorDark1Brush"             Color="#AA0000"/>
    <SolidColorBrush x:Key="SystemAccentColorDark2Brush"             Color="#880000"/>
    <SolidColorBrush x:Key="SystemAccentColorLight1Brush"            Color="#DD1111"/>
    <SolidColorBrush x:Key="SystemAccentColorLight2Brush"            Color="#FF0033"/>

    <!-- These are the actual keys WPF-UI Button uses for Appearance="Primary" -->
    <Color x:Key="SystemAccentColorSecondary">#AA0000</Color>
    <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush"      Color="#CC0000"/>
    <SolidColorBrush x:Key="ControlStrongFillColorDisabledBrush"     Color="#3A1010"/>

    <!-- Kill green/yellow snackbars - make them red -->
    <SolidColorBrush x:Key="SystemFillColorSuccessBrush"             Color="#CC0000"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush"             Color="#AA0000"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush"            Color="#880000"/>
    <Color x:Key="SystemFillColorSuccess">#CC0000</Color>
    <Color x:Key="SystemFillColorCaution">#AA0000</Color>
    <Color x:Key="SystemFillColorCritical">#880000</Color>

</ResourceDictionary>
