<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- CYBERPUNK ANIMATIONS & EFFECTS -->

    <!-- Matrix Rain Animation -->
    <Storyboard x:Key="MatrixRainStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetName="MatrixText1" 
                        Storyboard.TargetProperty="(Canvas.Top)"
                        From="-100" To="600" Duration="0:0:3"/>
        <DoubleAnimation Storyboard.TargetName="MatrixText2" 
                        Storyboard.TargetProperty="(Canvas.Top)"
                        From="-100" To="600" Duration="0:0:4" BeginTime="0:0:1"/>
        <DoubleAnimation Storyboard.TargetName="MatrixText3" 
                        Storyboard.TargetProperty="(Canvas.Top)"
                        From="-100" To="600" Duration="0:0:2.5" BeginTime="0:0:0.5"/>
    </Storyboard>

    <!-- Pulsing Glow Animation -->
    <Storyboard x:Key="PulsingGlowStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                        From="15" To="35" Duration="0:0:2" AutoReverse="True"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                        From="0.6" To="1.2" Duration="0:0:2" AutoReverse="True"/>
    </Storyboard>

    <!-- Glitch Effect Animation -->
    <Storyboard x:Key="GlitchStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                        From="0" To="2" Duration="0:0:0.05" BeginTime="0:0:5"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                        From="2" To="-1" Duration="0:0:0.05" BeginTime="0:0:5.05"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                        From="-1" To="0" Duration="0:0:0.05" BeginTime="0:0:5.1"/>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                        From="1" To="0.8" Duration="0:0:0.05" BeginTime="0:0:5" AutoReverse="True"/>
    </Storyboard>

    <!-- Scanning Line Animation -->
    <Storyboard x:Key="ScanLineStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                        From="-50" To="500" Duration="0:0:3"/>
    </Storyboard>

    <!-- Hexagon Rotation Animation -->
    <Storyboard x:Key="HexRotationStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                        From="0" To="360" Duration="0:0:20"/>
    </Storyboard>

    <!-- Loading Spinner Animation -->
    <Storyboard x:Key="LoadingSpinnerStoryboard" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                        From="0" To="360" Duration="0:0:1"/>
    </Storyboard>

    <!-- Type Writer Effect -->
    <Storyboard x:Key="TypeWriterStoryboard">
        <StringAnimationUsingKeyFrames Storyboard.TargetProperty="Text" Duration="0:0:2">
            <DiscreteStringKeyFrame Value="" KeyTime="0:0:0"/>
            <DiscreteStringKeyFrame Value="K" KeyTime="0:0:0.1"/>
            <DiscreteStringKeyFrame Value="KR" KeyTime="0:0:0.2"/>
            <DiscreteStringKeyFrame Value="KRA" KeyTime="0:0:0.3"/>
            <DiscreteStringKeyFrame Value="KRAK" KeyTime="0:0:0.4"/>
            <DiscreteStringKeyFrame Value="KRAKE" KeyTime="0:0:0.5"/>
            <DiscreteStringKeyFrame Value="KRAKEN" KeyTime="0:0:0.6"/>
            <DiscreteStringKeyFrame Value="KRAKEN " KeyTime="0:0:0.7"/>
            <DiscreteStringKeyFrame Value="KRAKEN U" KeyTime="0:0:0.8"/>
            <DiscreteStringKeyFrame Value="KRAKEN UN" KeyTime="0:0:0.9"/>
            <DiscreteStringKeyFrame Value="KRAKEN UNL" KeyTime="0:0:1.0"/>
            <DiscreteStringKeyFrame Value="KRAKEN UNLO" KeyTime="0:0:1.1"/>
            <DiscreteStringKeyFrame Value="KRAKEN UNLOC" KeyTime="0:0:1.2"/>
            <DiscreteStringKeyFrame Value="KRAKEN UNLOCK" KeyTime="0:0:1.3"/>
            <DiscreteStringKeyFrame Value="KRAKEN UNLOCKE" KeyTime="0:0:1.4"/>
            <DiscreteStringKeyFrame Value="KRAKEN UNLOCKER" KeyTime="0:0:1.5"/>
        </StringAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Cyber Slide In Animation -->
    <Storyboard x:Key="SlideInFromLeftStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                        From="-300" To="0" Duration="0:0:0.8">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                        From="0" To="1" Duration="0:0:0.8"/>
    </Storyboard>

    <!-- Fade In with Scale Animation -->
    <Storyboard x:Key="FadeInScaleStoryboard">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                        From="0" To="1" Duration="0:0:1"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                        From="0.5" To="1" Duration="0:0:1">
            <DoubleAnimation.EasingFunction>
                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                        From="0.5" To="1" Duration="0:0:1">
            <DoubleAnimation.EasingFunction>
                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

</ResourceDictionary>