<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Style x:Key="KrakenCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource KrakenCardGradient}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="22"/>
    </Style>

    <Style x:Key="KrakenStatCard" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A0505" Offset="0"/>
                    <GradientStop Color="#0D0000" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#440B0B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinHeight" Value="52"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#E10600" BlurRadius="14" ShadowDepth="0" Opacity="0.08"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource KrakenRedBrush}"/>
                <Setter Property="Background" Value="#181010"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="KrakenStatLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource KrakenRedGlowBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="KrakenStatValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="KrakenSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
    </Style>

    <Style x:Key="KrakenSectionSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="20"/>
    </Style>

    <Style x:Key="KrakenHeroTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
    </Style>

    <Style x:Key="KrakenBrandTag" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource KrakenRedNeonBrush}"/>
        <Setter Property="Opacity" Value="0.95"/>
    </Style>

    <Style x:Key="KrakenSocialButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Secondary"/>
        <Setter Property="Padding" Value="18,11"/>
        <Setter Property="Margin" Value="0,0,10,10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="KrakenPrimaryButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Primary"/>
        <Setter Property="Padding" Value="26,13"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="#CC0000"/>
        <Setter Property="MouseOverBackground" Value="#FF0033"/>
        <Setter Property="PressedBackground" Value="#990000"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style x:Key="KrakenFeatureTile" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#220505" Offset="0"/>
                    <GradientStop Color="#0D0000" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#551111"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Margin" Value="0,0,12,12"/>
        <Setter Property="MinWidth" Value="148"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF0033" BlurRadius="12" ShadowDepth="0" Opacity="0.06"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource KrakenRedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="KrakenPageHost" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource NeonGridBackground}"/>
    </Style>

    <Style x:Key="KrakenSettingsCard" TargetType="Border" BasedOn="{StaticResource KrakenCardBorder}">
        <Setter Property="Margin" Value="0,0,0,24"/>
        <Setter Property="Padding" Value="24,20"/>
    </Style>

    <Style x:Key="KrakenSettingRow" TargetType="Grid">
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="MinHeight" Value="48"/>
    </Style>

    <Style x:Key="KrakenSettingLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KrakenSettingHint" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxWidth" Value="520"/>
        <Setter Property="Opacity" Value="0.7"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <Style x:Key="KrakenActionButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Secondary"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <!-- Global TextBox Style with Red Borders - overrides WPF-UI blue -->
    <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
        <Setter Property="BorderBrush" Value="#CC0000"/>
        <Setter Property="Background" Value="#111111"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CaretBrush" Value="#FF0033"/>
        <Setter Property="Padding" Value="10,8"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="#FF0033"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#FF0033"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!-- TabItem - selected = red underline only, hover = subtle dark -->
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="#777"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="bg" Background="Transparent"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent"
                            Padding="14,8" Height="40">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bg" Property="BorderBrush" Value="#CC0000"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#CCC"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabControl - full dark template -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="#0A0A0A"/>
        <Setter Property="BorderBrush" Value="#1A1A1A"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#0D0D0D"
                                BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                            <TabPanel x:Name="HeaderPanel" IsItemsHost="True"
                                      Background="Transparent" KeyboardNavigation.TabIndex="1"
                                      VerticalAlignment="Top" Height="40"/>
                        </Border>
                        <Border Grid.Row="1" Background="#0A0A0A" BorderThickness="0">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="0" SnapsToDevicePixels="True"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>