<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Thickness x:Key="PageMargin">24</Thickness>

    <!-- KrakenXboxUnlocker — red neon gaming shell -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#050505"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#0C0C0C"/>
    <SolidColorBrush x:Key="LayerFillColorSecondaryBrush" Color="#141414"/>
    <SolidColorBrush x:Key="LayerFillColorTertiaryBrush" Color="#1E1E1E"/>

    <SolidColorBrush x:Key="KrakenRedBrush" Color="#E10600"/>
    <SolidColorBrush x:Key="KrakenRedGlowBrush" Color="#FF3344"/>
    <SolidColorBrush x:Key="KrakenRedDarkBrush" Color="#990000"/>
    <SolidColorBrush x:Key="KrakenRedMutedBrush" Color="#3A0808"/>
    <SolidColorBrush x:Key="KrakenRedNeonBrush" Color="#FF0044"/>

    <SolidColorBrush x:Key="PrimaryFillColorDefaultBrush" Color="#E10600"/>
    <SolidColorBrush x:Key="PrimaryFillColorSecondaryBrush" Color="#FF1744"/>
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#C62828"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#FF0033"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#CC0000"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#3A1010"/>
    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#FF3344"/>
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#FF0033"/>
    <SolidColorBrush x:Key="SystemAccentColorDark1Brush" Color="#CC0000"/>
    <SolidColorBrush x:Key="SystemAccentColorDark2Brush" Color="#990000"/>
    <SolidColorBrush x:Key="SystemAccentColorLight1Brush" Color="#FF3333"/>
    <SolidColorBrush x:Key="TextControlFocusedBorderBrush" Color="#FF0033"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#CC0000"/>
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#FF0033"/>
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#FF3344"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#9A9A9A"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#5C5C5C"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="#4A1010"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#101010"/>
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#5C1515"/>

    <!-- Override WPF-UI specific brushes to force red theme -->
    <SolidColorBrush x:Key="SystemFillColorSolidNeutralBackgroundBrush" Color="#050505"/>
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="#0C0C0C"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#050505"/>
    <SolidColorBrush x:Key="NavigationViewContentBackgroundBrush" Color="#050505"/>
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#0C0C0C"/>
    
    <!-- Navigation View styling -->
    <SolidColorBrush x:Key="NavigationViewItemBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#2A0A0A"/>
    <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#1A0A0A"/>
    <SolidColorBrush x:Key="NavigationViewItemForeground" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#FF3344"/>
    
    <!-- Gradients -->
    <LinearGradientBrush x:Key="KrakenCardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#141414" Offset="0"/>
        <GradientStop Color="#0C0C0C" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="KrakenAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E10600" Offset="0"/>
        <GradientStop Color="#FF3344" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KrakenHeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0D0D0D" Offset="0"/>
        <GradientStop Color="#120808" Offset="0.5"/>
        <GradientStop Color="#0D0D0D" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="NeonGridBackground" Color="#0A0A0A"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#141414"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#1A1A1A"/>

</ResourceDictionary>